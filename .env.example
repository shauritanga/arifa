# ─────────────────────────────────────────────────────────────
# ARIFA — environment configuration
# Copy to ".env.local" and fill in real values.
# ─────────────────────────────────────────────────────────────

# ─── Site ────────────────────────────────────────────────────
# Must be the public origin. Airpay whitelists this domain and builds the
# donor's return URL from it.
NEXT_PUBLIC_SITE_URL="https://arifa.org"

# ─── Database (PostgreSQL) ───────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/arifa?schema=public"

# ─── Airpay Payment Gateway (Tanzania) ───────────────────────
# All six values come from the Settings page of the Airpay merchant account.
AIRPAY_MERCHANT_ID=""
AIRPAY_USERNAME=""
AIRPAY_PASSWORD=""
# Airpay calls this the "API key". It salts the `privatekey` sent with checkout —
# it is NOT the client secret below, and swapping the two silently breaks payment.
AIRPAY_API_KEY=""
# OAuth client credentials, used to mint the short-lived checkout token.
AIRPAY_CLIENT_ID=""
AIRPAY_CLIENT_SECRET=""
# Timeout (ms) for each outbound Airpay HTTP call. Optional, defaults to 15000.
AIRPAY_TIMEOUT_MS="15000"

# All six AIRPAY_* values plus NEXT_PUBLIC_SITE_URL are REQUIRED — payments fail
# fast (with a clear error) if any are missing. Airpay Tanzania has no separate
# sandbox host; you test against the live gateway with small amounts.
#
# IMPORTANT — one-time setup Airpay must do on the merchant account. Airpay does
# not accept a return URL per transaction, so these are registered once:
#   Domain URL:   https://arifa.org
#   Response URL: https://arifa.org/api/airpay/callback
#   IPN URL:      https://arifa.org/api/airpay/ipn
# The domain must also be whitelisted, or Airpay refuses the checkout with
# "Invalid Domain" before any payment page is shown.
#
# NOTE: these credentials are shared with the ICAFoW site. Confirm with Airpay
# that arifa.org is registered as an ADDITIONAL domain and has not replaced
# ICAFoW's Response/IPN URLs on the same merchant account.

# ─── Admin dashboard (NextAuth) ──────────────────────────────
# Session signing secret. Generate: openssl rand -base64 32
AUTH_SECRET=""
# Seed credentials for the FIRST admin user: `npx prisma db seed`.
# Re-running the seed resets this user's password (use it to recover a lockout).
# Every other admin is created from inside the dashboard, at /admin/users.
ADMIN_EMAIL="admin@arifa.org"
ADMIN_PASSWORD=""

# ─── Background reconciliation (cron) ────────────────────────
# Shared secret required to call /api/cron/reconcile-donations.
# Generate: openssl rand -base64 32
CRON_SECRET=""
# Minutes an unpaid checkout may stay open before the reconciler marks it
# CANCELLED (the gateway is re-checked first; never cancels a paid donation).
PAYMENT_ABANDON_MINUTES="60"
