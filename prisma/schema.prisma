// ARIFA — donation / sponsorship payments via the Airpay Tanzania gateway.
//
// A donation IS the payment: unlike a conference registration there is nothing
// to fulfil afterwards, so the donor's details and the gateway attempt live on
// one row. `reference` is the stable key the donor sees and the status page
// looks up; `gatewayOrderId` changes on every retry attempt.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DonationType {
  DONATION
  SPONSORSHIP
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CARD
  MOBILE_MONEY
  UNSET
}

/// One row per donation/sponsorship intent.
model Donation {
  id        String        @id @default(cuid())
  reference String        @unique // e.g. ARF-7F3K9Q — shown to the donor
  type      DonationType  @default(DONATION)
  status    PaymentStatus @default(PENDING)
  method    PaymentMethod @default(UNSET)

  donorName    String
  email        String
  phone        String
  organization String?
  packageName  String?
  message      String?

  /// Whole Tanzanian shillings. Airpay bills TZS and the donor enters TZS, so
  /// this is both the pledge and the exact charge sent to the gateway — it is
  /// what the callback's reported amount is verified against before settling.
  amount   Int
  currency String @default("TZS")

  /// Retry counter → a fresh, unique gateway orderid per attempt.
  attempt        Int     @default(0)
  gatewayOrderId String? @unique // per-attempt orderid sent to Airpay
  gatewayTransId String? // Airpay's own transaction id (APTRANSACTIONID)
  gatewayPayload Json? // raw callback / verify response, for audit
  failureReason  String?

  paidAt    DateTime?
  events    DonationEvent[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([status])
  @@index([email])
}

/// Editable site content, previously hardcoded in JSON files and inline arrays
/// inside the page files. Shipped content is seeded from prisma/content-seed.json.
///
/// One table rather than seven: the collections (research projects, team,
/// certifications, publications, courses, jobs, events) share no fields beyond a
/// title and an image, so the type-specific parts live in `data` and the shape
/// of each is declared once in lib/content.js. Seven near-identical CRUD screens
/// would be a lot more code for no gain.
model ContentItem {
  id         String  @id @default(cuid())
  collection String
  /// The identifier the old data used, where it appeared in a URL — keeping it
  /// means /research/research-projects/101 and the certification pages do not
  /// break. Null for collections that were never addressable.
  slug       String?
  title      String
  image      String?
  /// Sub-grouping within a collection: team section, publication year,
  /// certification category, Upcoming/Past for events.
  group      String?
  /// Type-specific fields; see COLLECTIONS in lib/content.js.
  data       Json    @default("{}")
  position   Int     @default(0)
  published  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([collection, slug])
  @@index([collection, published, position])
}

enum SubmissionStatus {
  NEW
  READ
  ARCHIVED
}

/// Enquiries from the public contact form.
model ContactMessage {
  id        String           @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  subject   String
  message   String
  status    SubmissionStatus @default(NEW)
  createdAt DateTime         @default(now())

  @@index([status])
}

/// Applications for a certification or short course. Both the standalone apply
/// page and the "Apply Now" modal submit here — they are the same application,
/// only presented differently, so `programme` records what was applied for.
model Application {
  id         String           @id @default(cuid())
  firstName  String
  lastName   String
  email      String
  phone      String
  /// Title of the certification / course applied for.
  programme  String
  /// Certification id from the source data, when the apply page supplied one.
  programmeId String?
  occupation String?
  motivation String

  /// CVs are held in the database rather than on disk: volumes are low, and it
  /// keeps the file atomic with the record (and inside the same backup).
  cvName String?
  cvType String?
  cvData Bytes?

  status    SubmissionStatus @default(NEW)
  createdAt DateTime         @default(now())

  @@index([status])
  @@index([email])
}

/// Admin / staff users for the dashboard (NextAuth credentials).
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("admin") // admin | viewer
  createdAt    DateTime @default(now())
}

/// Global dynamic configuration (contact details, socials).
model SiteSetting {
  id        String   @id @default("global")
  data      Json
  updatedAt DateTime @updatedAt
}

/// Append-only audit of every status transition: real-money forensics for what
/// moved a donation, and from where (browser redirect / webhook / reconcile
/// sweep / foreground poll).
model DonationEvent {
  id         String         @id @default(cuid())
  donationId String
  donation   Donation       @relation(fields: [donationId], references: [id], onDelete: Cascade)
  fromStatus PaymentStatus?
  toStatus   PaymentStatus
  source     String // REDIRECT | CALLBACK | RECONCILE | POLL | INITIATE | SYSTEM
  amount     Int? // gateway-reported amount at the time, if any
  message    String?
  createdAt  DateTime       @default(now())

  @@index([donationId])
}
